{
  "info": {
    "name": "School API .NET (Scores) - Production",
    "_postman_id": "school-api-dotnet-production",
    "description": "Scores API - C# .NET 8\nEnvironment: Production\nBase URL: https://DEPLOY_FIRST.execute-api.us-east-1.amazonaws.com/Prod\n\nFlow: 1) Login → 2) Token auto-saved → 3) Get/Record scores.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://DEPLOY_FIRST.execute-api.us-east-1.amazonaws.com/Prod",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@school.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set(\"token\", res.data.token);",
                  "    console.log(\"Token saved to collection variable\");",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scores",
      "item": [
        {
          "name": "Get Scores",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/scores",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "scores"
              ],
              "query": [
                {
                  "key": "studentId",
                  "value": "1",
                  "description": "Student ID (required)"
                },
                {
                  "key": "gradeId",
                  "value": "1",
                  "description": "Grade ID (required)"
                },
                {
                  "key": "year",
                  "value": "2026",
                  "description": "Year (required)"
                },
                {
                  "key": "month",
                  "value": "4",
                  "description": "Month 1-12 (required)"
                }
              ]
            }
          }
        },
        {
          "name": "Record Score",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/scores",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "scores"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": 1,\n  \"subjectId\": 1,\n  \"gradeId\": 1,\n  \"year\": 2026,\n  \"month\": 4,\n  \"score\": 9.5\n}"
            }
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    }
  ]
}